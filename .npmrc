# NPM Configuration for FutureTracker
#
# IMPORTANT: legacy-peer-deps is required due to react-helmet-async@2.0.5
# not officially supporting React 19 yet (only supports React 16-18).
#
# This setting allows npm to install despite the peer dependency mismatch.
# The library works correctly with React 19 - the peer dependency is overly
# restrictive.
#
# MONITOR: Watch for updates to react-helmet-async that add React 19 support.
# Once officially supported, this setting can be removed.
#
# Last verified: 2026-01-18
# Affected package: react-helmet-async@2.0.5

legacy-peer-deps=true
