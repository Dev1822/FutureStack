# Backend Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Frontend URL for CORS (use comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000

# Clerk Authentication (get from clerk.com dashboard)
CLERK_SECRET_KEY=sk_test_...

# Clerk JWT Public Key (REQUIRED for production - prevents network dependency)
# Get from: Clerk Dashboard > Configure > API Keys > Show JWT Public Key
# Copy the entire PEM key including -----BEGIN PUBLIC KEY----- and -----END PUBLIC KEY-----
# In Render/hosting, add as multi-line env var or replace newlines with \n
CLERK_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----

# Supabase Database (get from supabase.com project settings)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
