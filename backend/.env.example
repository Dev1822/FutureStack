# Backend Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Frontend URL for CORS (use comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000

# Clerk Authentication (get from clerk.com dashboard)
CLERK_SECRET_KEY=sk_test_...

# Clerk JWT Public Key for networkless verification (RECOMMENDED for Render/Railway)
# Get from: Clerk Dashboard > API Keys > Advanced > JWT Public Key (PEM format)
# This avoids outbound HTTP requests to Clerk's API servers during token verification
# Without this, the backend must fetch JWKS from Clerk on every request, which can fail
# on some hosting platforms with "TypeError: fetch failed"
CLERK_JWT_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# Supabase Database (get from supabase.com project settings)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
