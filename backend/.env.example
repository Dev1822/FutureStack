# Backend Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Frontend URL for CORS (use comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000

# Clerk Authentication (get from clerk.com dashboard)
CLERK_SECRET_KEY=sk_test_...

# Clerk JWT Public Key (RECOMMENDED for production)
# Enables local JWT verification without network calls to Clerk's JWKS endpoint.
# This prevents "TypeError: fetch failed" errors on platforms like Render/Railway.
#
# Get from: Clerk Dashboard > Configure > API Keys > Show JWT Public Key
#
# Accepted formats (middleware normalizes automatically):
#   1. Multi-line PEM (if your hosting supports it)
#   2. Single-line with \n escape sequences (most common)
#
# Example (single-line format):
# CLERK_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkq...\n-----END PUBLIC KEY-----

# Supabase Database (get from supabase.com project settings)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional: database password for one-time local migrations (npm run db:migrate:ai)
# Supabase Dashboard → Project Settings → Database → Database password
# SUPABASE_DB_PASSWORD=

# Share links
# Used to encrypt recoverable share tokens so owners can copy active links again.
# Generate with: openssl rand -base64 32
SHARE_LINK_ENCRYPTION_KEY=replace-with-random-32-byte-secret

# =============================================================================
# AI Resume Checker (agentic pipeline — powered by interviewstreet/hiring-agent
# architecture, MIT © HackerRank, reimplemented in Node.js)
# =============================================================================

# Set to 'false' to disable the feature entirely (e.g. when no API key is configured)
RESUME_AI_ENABLED=true

# LLM provider: 'gemini' (default) or 'ollama'
# Adding @ai-sdk/openai / @ai-sdk/anthropic requires a new case in lib/llm/index.js
LLM_PROVIDER=gemini

# Model name for the selected provider
# Gemini examples: gemini-3.1-flash-lite, gemini-2.5-flash, gemini-2.5-pro
# Ollama examples: llama3.2, qwen2.5, gemma3:4b
LLM_MODEL=gemini-3.1-flash-lite

# Required when LLM_PROVIDER=gemini
# Get a free key at: https://aistudio.google.com/api-keys
GEMINI_API_KEY=

# Required when LLM_PROVIDER=ollama
# Default points to a locally running Ollama server
OLLAMA_BASE_URL=http://localhost:11434

# Optional: GitHub Personal Access Token for higher API rate limits (60 → 5000 req/hr)
# The GitHub enrichment stage works without a token but will be slower or skip if rate-limited
# Get from: https://github.com/settings/tokens (needs no scopes for public repos)
GITHUB_TOKEN=

# Optional: dedicated secret for encrypting user BYOK API keys (falls back to SHARE_LINK_ENCRYPTION_KEY)
# Generate with: openssl rand -base64 32
AI_KEY_ENCRYPTION_KEY=
